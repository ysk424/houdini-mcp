<?xml version="1.0" encoding="UTF-8"?>
<shelfDocument>
  <toolshelf name="houdinimcp" label="HoudiniMCP">
    <memberTool name="houdinimcp_terminal"/>
    <memberTool name="houdinimcp_toggle_server"/>
  </toolshelf>

  <tool name="houdinimcp_terminal" label="Claude Terminal" icon="hicon:/SVGIcons.index?IM_NewViewport.svg">
    <helpText><![CDATA[Open the Claude Terminal panel in a floating window.]]></helpText>
    <script scriptType="python"><![CDATA[
import hou

desktop = hou.ui.curDesktop()
panel = desktop.createFloatingPanel(hou.paneTabType.PythonPanel)
pane_tab = panel.paneTabOfType(hou.paneTabType.PythonPanel)
pane_tab.setActiveInterface(hou.pypanel.interfaceByName("claude_terminal"))
]]></script>
  </tool>

  <tool name="houdinimcp_toggle_server" label="Toggle MCP Server" icon="hicon:/SVGIcons.index?BUTTONS_connected.svg">
    <helpText><![CDATA[Start or stop the HoudiniMCP TCP server (localhost:9876).]]></helpText>
    <script scriptType="python"><![CDATA[
import hou
import houdinimcp

server = getattr(hou.session, "houdinimcp_server", None)
if (
    server is not None
    and getattr(server, "running", False)
    and getattr(server, "socket", None) is not None
):
    houdinimcp.stop_server()
    hou.ui.displayMessage("HoudiniMCP server stopped.")
else:
    server = houdinimcp.start_server()
    if server is not None:
        hou.ui.displayMessage("HoudiniMCP server started on localhost:9876.")
    else:
        hou.ui.displayMessage("HoudiniMCP server failed to start. Check the console.")
]]></script>
  </tool>
</shelfDocument>
